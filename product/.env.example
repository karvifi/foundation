# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/omnios?sslmode=require

# ── Auth (better-auth) ─────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-32-char-random-secret-here
BETTER_AUTH_URL=https://omnios.app

# ── JWT ────────────────────────────────────────────────────────────────────
OMNIOS_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# ── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...

# ── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── AI ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Cache (Upstash Redis) ──────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://....upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
